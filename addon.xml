<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.kodisimplestream"
version="0.6.1"
name="kodisimplestream"
provider-name="kecerim">
<requires>
  <import addon="xbmc.python" version="3.0.0"/>
  <import addon="script.module.requests" version="2.31.0"/>
  <import addon="script.module.xmltodict" version="0.12.0+matrix.2"/>
  <import addon="script.module.beautifulsoup4" version="4.12.2"/>
</requires>
<extension point="xbmc.python.pluginsource" library="kodisimplestream.py">
  <provides>video</provides>
</extension>
<extension point="xbmc.addon.metadata">
  <summary lang="cs">KodiSimpleStream - Kodi plugin pro Webshare.cz</summary>
  <description lang="cs_CZ">Jednoduchý Kodi plugin pro přehrávání videí z Webshare.cz. Pro více informací navštivte https://github.com/Kecerim24/plugin.video.kodisimplestream</description>
  <platform>all</platform>
  <settings>
    <setting id="username" type="text" label="Username" default="" />
    <setting id="password" type="text" label="Password" option="hidden" default="" />
    <setting label="tmdbh_auto_play_best" type="bool" id="tmdbh_auto_play_best" default="false" />
    <setting label="tmdbh_auto_play_min_score" type="number" id="tmdbh_auto_play_min_score" default="80" />
    <setting label="tmdbh_max_results" type="number" id="tmdbh_max_results" default="20" />
    <setting label="tmdbh_prefer_quality" type="text" id="tmdbh_prefer_quality" default="1080p_or_best" />
    <setting label="tmdbh_show_debug_scores" type="bool" id="tmdbh_show_debug_scores" default="false" />
  </settings>
</extension>
</addon>

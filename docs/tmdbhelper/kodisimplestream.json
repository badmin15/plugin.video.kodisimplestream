{
  "name": "KodiSimpleStream",
  "plugin": "plugin.video.kodisimplestream",
  "priority": 500,
  "is_resolvable": "true",
  "assert": {
    "play_movie": ["title"],
    "play_episode": ["showname", "season", "episode"]
  },
  "play_movie": "plugin://plugin.video.kodisimplestream/?action=tmdbh_play&mediatype=movie&title={title}&originaltitle={originaltitle}&year={year}&imdb_id={imdb_id}&tmdb_id={tmdb_id}",
  "play_episode": "plugin://plugin.video.kodisimplestream/?action=tmdbh_play&mediatype=episode&showname={showname}&show_originaltitle={show_originaltitle}&season={season}&episode={episode}&episode_title={title}&aired={premiered}&year={year}&imdb_id={imdb_id}&tmdb_id={tmdb_id}"
}
